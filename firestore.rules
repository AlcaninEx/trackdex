rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helpers ────────────────────────────────────────────────────────────
    function authed() { return request.auth != null; }
    // nombre de usuario a partir del email interno usuario@users.trackdex.app
    function uname() { return request.auth.token.email.split('@')[0]; }
    function isAdmin() { return authed() && request.auth.token.email == 'xelark@users.trackdex.app'; }

    // ── Cuentas globales ───────────────────────────────────────────────────
    match /globalUsers/{userId} {
      // "get" abierto: necesario para el chequeo de registro y la migración de
      // cuentas antiguas (que aún guardan password). Cerrar cuando todos migren.
      allow get: if true;
      allow list: if isAdmin(); // para la copia de seguridad del admin
      allow create, update: if authed() && (uname() == userId || isAdmin());
      // cada usuario puede borrar su propia cuenta (RGPD), y el admin cualquiera
      allow delete: if authed() && (uname() == userId || isAdmin());
    }

    // ── Comunidades ────────────────────────────────────────────────────────
    match /communities/{cid} {
      allow read: if authed();
      allow create: if authed() && request.resource.data.ownerId == uname();
      // unirse / editar escriben el doc completo; requiere sesión iniciada
      allow update: if authed();
      // borrar: solo el creador o el admin
      allow delete: if authed() && (resource.data.ownerId == uname() || isAdmin());

      // Chat de la comunidad
      match /messages/{mid} {
        allow read: if authed()
          && get(/databases/$(database)/documents/communities/$(cid)).data.members[uname()] != null;
        allow create: if authed()
          && get(/databases/$(database)/documents/communities/$(cid)).data.members[uname()] != null
          && request.resource.data.uid == uname()
          && request.resource.data.text is string
          && request.resource.data.text.size() > 0
          && request.resource.data.text.size() <= 300;
        // borrar: el autor, el dueño de la comunidad o el admin
        allow delete: if authed()
          && (resource.data.uid == uname()
              || get(/databases/$(database)/documents/communities/$(cid)).data.ownerId == uname()
              || isAdmin());
      }

      // Perfiles (equipos) dentro de cada comunidad
      match /profiles/{profileName} {
        allow read: if authed();
        // escribir solo si eres miembro de esa comunidad
        allow write: if authed()
          && get(/databases/$(database)/documents/communities/$(cid)).data.members[uname()] != null;
      }
    }

    // ── Mensajes privados (DM) entre dos usuarios ──────────────────────────
    // El id de conversación es "usuarioA~usuarioB" (ordenados). Solo los dos
    // participantes pueden leer o escribir en su conversación.
    match /dms/{convId}/messages/{mid} {
      allow read: if authed() && (uname() in convId.split('~'));
      allow create: if authed()
        && (uname() in convId.split('~'))
        && request.resource.data.uid == uname()
        && request.resource.data.text is string
        && request.resource.data.text.size() > 0
        && request.resource.data.text.size() <= 500;
      // borrar: solo el autor del mensaje
      allow delete: if authed() && resource.data.uid == uname();
    }

    // ── Configuración global (rotación de Megas, etc.) ─────────────────────
    match /config/{doc} {
      allow read: if authed();
      allow write: if isAdmin();
    }

    // ── Todo lo demás: cerrado ─────────────────────────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
